# Copy to .env and edit before running `docker compose up --build -d`.

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=a06_todo

# --- Express API ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Comma-separated origins allowed by CORS. Include both the local docker
# host:port pairs and your public proxy URLs.
CORS_ORIGIN=http://localhost:87,http://localhost:89,https://mtiker-js-vue-a6.proxy.itcollege.ee,https://mtiker-js-react-a6.proxy.itcollege.ee

# --- Frontends (build-time inlined into the bundles) ---
VITE_API_BASE_URL=https://mtiker-js-express.proxy.itcollege.ee/api/v1
NEXT_PUBLIC_API_BASE_URL=https://mtiker-js-express.proxy.itcollege.ee
