# Copy to .env and adjust values as needed; the deploy script reads /home/gitlab-runner/mtiker-js-a07.env in CI.

# Absolute backend URL baked into the JS bundle at build time.
# Defaults to the public cweb assignment-05 final2 host.
VITE_API_BASE_URL=https://mtiker-cweb-4.proxy.itcollege.ee

# Host port mapped to the container's :3000. The TalTech proxy
# (mtiker-js-a07.proxy.itcollege.ee) is configured to forward to this port.
A07_PORT=90

# Optional: pre-built image tag to pull instead of building.
# A07_CLIENT_IMAGE=registry.gitlab.cs.ttu.ee/.../mtiker-js-a07-client:latest

# Optional: docker compose project name (default mtiker-js-a07).
# COMPOSE_PROJECT_NAME=mtiker-js-a07
