@model AdminGymsPageViewModel
@inject IStringLocalizer<SharedResources> L
<section class="panel">
    <div class="d-flex justify-content-between align-items-center">
        <h1>@L["Gyms"]</h1>
        <a asp-area="Admin" asp-controller="Gyms" asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>@L["CreateGym"]
        </a>
    </div>
    <table class="data-table">
        <thead>
        <tr>
            <th>@L["Name"]</th>
            <th>@L["Code"]</th>
            <th>@L["City"]</th>
            <th>@L["Status"]</th>
            <th>@L["Actions"]</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var gym in Model.Gyms)
        {
            <tr>
                <td>@gym.Name</td>
                <td>@gym.Code</td>
                <td>@gym.City</td>
                <td>@(gym.IsActive ? L["Active"] : L["Inactive"])</td>
                <td>
                    <a asp-area="Admin" asp-controller="Gyms" asp-action="Edit" asp-route-id="@gym.Id" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-pencil me-1"></i>@L["Edit"]
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</section>
