@model AdminMaintenanceTaskDeleteViewModel
@inject IStringLocalizer<SharedResources> L

<section class="panel">
    <p class="eyebrow">@L["AdminWorkspace"]</p>
    <h1>@L["DeleteMaintenanceTask"]</h1>
    <p>@L["ActiveGym"]: <strong>@Model.GymCode</strong></p>
</section>

<section class="panel">
    <p>@L["ConfirmMaintenanceTaskRemoval"]</p>
    <dl class="definition-list">
        <dt>@L["Equipment"]</dt>
        <dd>@Model.EquipmentName</dd>
        <dt>@L["Type"]</dt>
        <dd>@Model.TaskType</dd>
        <dt>@L["Status"]</dt>
        <dd>@Model.Status</dd>
        <dt>@L["Due"]</dt>
        <dd>@(Model.DueAtUtc?.ToLocalTime().ToString("g") ?? "-")</dd>
    </dl>

    <form asp-area="Admin" asp-controller="Operations" asp-action="TaskDelete" asp-route-id="@Model.Id" method="post" class="form-grid">
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="form-actions">
            <button type="submit" class="danger">@L["DeleteMaintenanceTask"]</button>
            <a asp-area="Admin" asp-controller="Operations" asp-action="Index" class="secondary">@L["Cancel"]</a>
        </div>
    </form>
</section>
