@model AdminDashboardViewModel
@inject IStringLocalizer<SharedResources> L
@inject IConfiguration Configuration
@{
    var hasSystemRole = Model.SystemRoles.Count > 0;
    var hasTenantAdminRole = Model.ActiveRole == "GymOwner" || Model.ActiveRole == "GymAdmin";
    var clientAppBaseUrl = ClientAppUrlResolver.GetBaseUrl(Configuration);
}
<section class="dashboard-grid">
    <article class="panel">
        <h1>@L["AdminArea"]</h1>
        <p>@L["ActiveGym"]: <strong>@(Model.ActiveGymCode ?? L["Platform"].Value)</strong></p>
        <p>@L["ActiveRole"]: <strong>@(Model.ActiveRole ?? string.Join(", ", Model.SystemRoles))</strong></p>
    </article>
    <article class="metric-card">
        <span>@L["Gyms"]</span>
        <strong>@Model.GymCount</strong>
    </article>
    <article class="metric-card">
        <span>@L["Members"]</span>
        <strong>@Model.MemberCount</strong>
    </article>
    <article class="metric-card">
        <span>@L["Sessions"]</span>
        <strong>@Model.SessionCount</strong>
    </article>
    <article class="metric-card">
        <span>@L["Maintenance"]</span>
        <strong>@Model.OpenMaintenanceTaskCount</strong>
    </article>
</section>
<section class="panel">
    <h2>@L["QuickLinks"]</h2>
    <div class="link-strip">
        @if (hasSystemRole)
        {
            <a asp-area="Admin" asp-controller="Gyms" asp-action="Index">@L["Gyms"]</a>
        }
        @if (hasTenantAdminRole)
        {
            <a asp-area="Admin" asp-controller="Members" asp-action="Index">@L["Members"]</a>
            <a asp-area="Admin" asp-controller="Memberships" asp-action="Index">@L["Memberships"]</a>
            <a asp-area="Admin" asp-controller="MembershipPackages" asp-action="Index">@L["MembershipPackages"]</a>
            <a asp-area="Admin" asp-controller="Sessions" asp-action="Index">@L["Sessions"]</a>
            <a asp-area="Admin" asp-controller="TrainingCategories" asp-action="Index">@L["TrainingCategories"]</a>
            <a asp-area="Admin" asp-controller="Operations" asp-action="Index">@L["Operations"]</a>
        }
    </div>
</section>

<section class="panel">
    <h2>@L["ClientArea"]</h2>
    <p class="muted-text">@L["ClientAppHint"]</p>
    <a class="primary" href="@clientAppBaseUrl">@L["OpenClientApp"]</a>
</section>
