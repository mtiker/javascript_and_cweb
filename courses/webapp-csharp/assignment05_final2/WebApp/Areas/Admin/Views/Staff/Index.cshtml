@model AdminStaffPageViewModel
@inject IStringLocalizer<SharedResources> L

<section class="panel">
    <p class="eyebrow">@L["AdminWorkspace"]</p>
    <h1>@L["Trainers"]</h1>
    <p>@L["ActiveGym"]: <strong>@Model.GymCode</strong></p>
    <p>
        <a asp-area="Admin" asp-controller="Staff" asp-action="Create" class="primary">@L["AddNewTrainer"]</a>
    </p>
</section>

<section class="panel">
    <h2>@L["TrainerDirectory"]</h2>
    @if (Model.Staff.Count == 0)
    {
        <p class="muted-text">@L["NoTrainersYet"]</p>
    }
    else
    {
        <table class="data-table">
            <thead>
            <tr>
                <th>@L["Code"]</th>
                <th>@L["Name"]</th>
                <th>@L["Status"]</th>
                <th>@L["Actions"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var member in Model.Staff)
            {
                <tr>
                    <td>@member.StaffCode</td>
                    <td>@member.FullName</td>
                    <td>@member.Status</td>
                    <td>
                        <a asp-area="Admin" asp-controller="Staff" asp-action="Edit" asp-route-id="@member.Id">@L["Edit"]</a>
                        <span> | </span>
                        <a asp-area="Admin" asp-controller="Staff" asp-action="Delete" asp-route-id="@member.Id">@L["Delete"]</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>
