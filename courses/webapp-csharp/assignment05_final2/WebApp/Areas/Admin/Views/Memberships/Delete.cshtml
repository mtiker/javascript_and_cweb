@model AdminMembershipDeleteViewModel
@inject IStringLocalizer<SharedResources> L

<section class="panel">
    <p class="eyebrow">@L["AdminWorkspace"]</p>
    <h1>@L["DeleteMembership"]</h1>
    <p>@L["ActiveGym"]: <strong>@Model.GymCode</strong></p>
</section>

<section class="panel">
    <p>@L["ConfirmMembershipRemoval"]</p>
    <dl class="definition-list">
        <dt>@L["Member"]</dt>
        <dd>@Model.MemberName</dd>
        <dt>@L["Package"]</dt>
        <dd>@Model.PackageName</dd>
        <dt>@L["Validity"]</dt>
        <dd>@Model.StartDate - @Model.EndDate</dd>
        <dt>@L["Status"]</dt>
        <dd>@Model.Status</dd>
    </dl>

    <form asp-area="Admin" asp-controller="Memberships" asp-action="Delete" asp-route-id="@Model.Id" method="post" class="form-grid">
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="form-actions">
            <button type="submit" class="danger">@L["DeleteMembership"]</button>
            <a asp-area="Admin" asp-controller="Memberships" asp-action="Index" class="secondary">@L["Cancel"]</a>
        </div>
    </form>
</section>
