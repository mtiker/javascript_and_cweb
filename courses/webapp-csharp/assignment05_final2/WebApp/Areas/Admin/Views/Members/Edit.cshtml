@model AdminMemberFormViewModel
@inject IStringLocalizer<SharedResources> L

<section class="panel">
    <p class="eyebrow">@L["AdminWorkspace"]</p>
    <h1>@L["EditMember"]</h1>
    <p>@L["ActiveGym"]: <strong>@Model.GymCode</strong></p>
</section>

<section class="panel">
    <form asp-area="Admin" asp-controller="Members" asp-action="Edit" asp-route-id="@Model.Id" method="post" class="form-grid">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
        <input type="hidden" asp-for="Id" />

        <div class="form-row">
            <label asp-for="FirstName">@L["FirstName"]</label>
            <input asp-for="FirstName" autocomplete="given-name" />
            <span asp-validation-for="FirstName" class="field-validation-error"></span>
        </div>

        <div class="form-row">
            <label asp-for="LastName">@L["LastName"]</label>
            <input asp-for="LastName" autocomplete="family-name" />
            <span asp-validation-for="LastName" class="field-validation-error"></span>
        </div>

        <div class="form-row">
            <label asp-for="MemberCode">@L["MemberCode"]</label>
            <input asp-for="MemberCode" />
            <span asp-validation-for="MemberCode" class="field-validation-error"></span>
        </div>

        <div class="form-row">
            <label asp-for="PersonalCode">@L["PersonalCode"]</label>
            <input asp-for="PersonalCode" />
            <span asp-validation-for="PersonalCode" class="field-validation-error"></span>
        </div>

        <div class="form-row">
            <label asp-for="DateOfBirth">@L["DateOfBirth"]</label>
            <input asp-for="DateOfBirth" />
            <span asp-validation-for="DateOfBirth" class="field-validation-error"></span>
        </div>

        <div class="form-row">
            <label asp-for="Status">@L["Status"]</label>
            <select asp-for="Status" asp-items="Html.GetEnumSelectList<Shared.Contracts.Enums.MemberStatus>()"></select>
            <span asp-validation-for="Status" class="field-validation-error"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="primary">@L["SaveChanges"]</button>
            <a asp-area="Admin" asp-controller="Members" asp-action="Index" class="secondary">@L["Cancel"]</a>
        </div>
    </form>
</section>
