@model AdminSessionFormViewModel
@inject IStringLocalizer<SharedResources> L

<section class="panel">
    <p class="eyebrow">@L["AdminWorkspace"]</p>
    <h1>@L["CreateSession"]</h1>
    <p>@L["ActiveGym"]: <strong>@Model.GymCode</strong></p>
</section>

<section class="panel">
    @if (Model.CategoryOptions.Count == 0)
    {
        <p class="muted-text">@L["NoCategoriesCreateFirst"]</p>
        <a asp-area="Admin" asp-controller="TrainingCategories" asp-action="Create" class="secondary">@L["AddNewCategory"]</a>
    }
    else
    {
        <form asp-area="Admin" asp-controller="Sessions" asp-action="Create" method="post" class="form-grid">
            <div asp-validation-summary="All" class="validation-summary-errors"></div>

            <div class="form-row">
                <label asp-for="CategoryId">@L["TrainingCategory"]</label>
                <select asp-for="CategoryId" asp-items="Model.CategoryOptions"></select>
                <span asp-validation-for="CategoryId" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Name">@L["Name"]</label>
                <input asp-for="Name" />
                <span asp-validation-for="Name" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Description">@L["Description"]</label>
                <textarea asp-for="Description" rows="3"></textarea>
                <span asp-validation-for="Description" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="StartAt">@L["StartTime"]</label>
                <input asp-for="StartAt" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" />
                <span asp-validation-for="StartAt" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="EndAt">@L["EndTime"]</label>
                <input asp-for="EndAt" type="datetime-local" asp-format="{0:yyyy-MM-ddTHH:mm}" />
                <span asp-validation-for="EndAt" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Capacity">@L["Capacity"]</label>
                <input asp-for="Capacity" type="number" min="1" />
                <span asp-validation-for="Capacity" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="BasePrice">@L["BasePrice"]</label>
                <input asp-for="BasePrice" type="number" step="0.01" min="0" />
                <span asp-validation-for="BasePrice" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="CurrencyCode">@L["CurrencyCode"]</label>
                <input asp-for="CurrencyCode" maxlength="3" />
                <span asp-validation-for="CurrencyCode" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="Status">@L["Status"]</label>
                <select asp-for="Status" asp-items="Html.GetEnumSelectList<Shared.Contracts.Enums.TrainingSessionStatus>()"></select>
                <span asp-validation-for="Status" class="field-validation-error"></span>
            </div>

            <div class="form-row">
                <label asp-for="TrainerStaffId">@L["Trainer"]</label>
                <select asp-for="TrainerStaffId" asp-items="Model.TrainerOptions">
                    <option value="">@L["Unassigned"]</option>
                </select>
                <span asp-validation-for="TrainerStaffId" class="field-validation-error"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="primary">@L["CreateSession"]</button>
                <a asp-area="Admin" asp-controller="Sessions" asp-action="Index" class="secondary">@L["Cancel"]</a>
            </div>
        </form>
    }
</section>
