@model SessionDetailPageViewModel
@inject IStringLocalizer<SharedResources> L
@{
    var statusMessage = TempData["StatusMessage"] as string;
}

<section class="panel">
    <p class="eyebrow">@Model.CategoryName</p>
    <h1>@Model.Session.Name</h1>
    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <p class="status-message">@statusMessage</p>
    }
    <p>@Model.Session.Description</p>
    <dl class="definition-list">
        <dt>@L["Starts"]</dt>
        <dd>@Model.Session.StartAtUtc.ToLocalTime():g</dd>
        <dt>@L["Ends"]</dt>
        <dd>@Model.Session.EndAtUtc.ToLocalTime():g</dd>
        <dt>@L["Capacity"]</dt>
        <dd>@Model.Session.Capacity</dd>
        <dt>@L["Price"]</dt>
        <dd>@Model.Session.BasePrice @Model.Session.CurrencyCode</dd>
        <dt>@L["Trainers"]</dt>
        <dd>@(Model.TrainerNames.Count == 0 ? L["NoTrainersAssigned"].Value : string.Join(", ", Model.TrainerNames))</dd>
    </dl>

    @if (Model.CanBook)
    {
        <form asp-action="Book" method="post" class="inline-form">
            <input type="hidden" name="id" value="@Model.Session.Id" />
            <label>
                @L["PaymentReference"]
                <input name="paymentReference" placeholder="@L["PaymentReferenceHint"]" />
            </label>
            <button type="submit">@L["BookSession"]</button>
        </form>
    }
    else if (Model.CurrentBookingId.HasValue)
    {
        <p>@L["CurrentBookingStatus"] <strong>@Model.CurrentBookingStatus</strong></p>
        <form asp-action="CancelBooking" method="post" class="inline-form">
            <input type="hidden" name="id" value="@Model.Session.Id" />
            <input type="hidden" name="bookingId" value="@Model.CurrentBookingId" />
            <button type="submit">@L["CancelBooking"]</button>
        </form>
    }

    <div class="link-strip">
        <a asp-action="Index">@L["BackToSessions"]</a>
        @if (Model.CanManageRoster)
        {
            <a asp-action="Roster" asp-route-id="@Model.Session.Id">@L["TrainerRoster"]</a>
        }
    </div>
</section>
