@model SessionsPageViewModel
@inject IStringLocalizer<SharedResources> L
<section class="panel">
    <h1>@L["Sessions"]</h1>
    <p>@L["Gym"]: <strong>@Model.GymCode</strong></p>
    @if (Model.Sessions.Count == 0)
    {
        <p class="muted-text">@L["NoSessionsScheduled"]</p>
    }
    else
    {
        <table class="data-table">
            <thead>
            <tr>
                <th>@L["Name"]</th>
                <th>@L["Start"]</th>
                <th>@L["End"]</th>
                <th>@L["Status"]</th>
                <th>@L["Price"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var session in Model.Sessions)
            {
                <tr>
                    <td>@session.Name</td>
                    <td>@session.StartAtUtc.ToLocalTime():g</td>
                    <td>@session.EndAtUtc.ToLocalTime():g</td>
                    <td>@session.Status</td>
                    <td>@session.BasePrice @session.CurrencyCode</td>
                    <td><a asp-action="Details" asp-route-id="@session.Id">@L["Details"]</a></td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>
