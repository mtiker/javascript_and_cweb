@model TrainerRosterPageViewModel
@using Shared.Contracts.Enums
@inject IStringLocalizer<SharedResources> L
@{
    var statusMessage = TempData["StatusMessage"] as string;
}

<section class="panel">
    <p class="eyebrow">@L["TrainerRoster"]</p>
    <h1>@Model.SessionName</h1>
    <p>@Model.StartAtUtc.ToLocalTime():g</p>
    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <p class="status-message">@statusMessage</p>
    }

    @if (Model.Bookings.Count == 0)
    {
        <p class="muted-text">@L["NoBookingsYet"]</p>
    }
    else
    {
        <table class="data-table">
            <thead>
            <tr>
                <th>@L["Member"]</th>
                <th>@L["Status"]</th>
                <th>@L["Payment"]</th>
                <th>@L["Attendance"]</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var booking in Model.Bookings)
            {
                <tr>
                    <td>@booking.MemberName</td>
                    <td>@booking.Status</td>
                    <td>@booking.ChargedPrice @(booking.PaymentRequired ? "paid/required" : "included/free")</td>
                    <td>
                        <form asp-action="UpdateAttendance" method="post" class="inline-form">
                            <input type="hidden" name="sessionId" value="@Model.SessionId" />
                            <input type="hidden" name="bookingId" value="@booking.BookingId" />
                            <select name="status">
                                <option value="@BookingStatus.Booked">@L["Booked"]</option>
                                <option value="@BookingStatus.Attended">@L["Attended"]</option>
                                <option value="@BookingStatus.NoShow">@L["NoShow"]</option>
                                <option value="@BookingStatus.Cancelled">@L["Cancelled"]</option>
                            </select>
                            <button type="submit">@L["Save"]</button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
    <a asp-action="Details" asp-route-id="@Model.SessionId">@L["BackToSession"]</a>
</section>
