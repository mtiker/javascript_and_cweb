@model MaintenanceTaskDetailPageViewModel
@using Shared.Contracts.Enums
@inject IStringLocalizer<SharedResources> L
@{
    var statusMessage = TempData["StatusMessage"] as string;
}

<section class="panel">
    <p class="eyebrow">@L["MaintenanceTask"]</p>
    <h1>@Model.Task.TaskType - @Model.EquipmentLabel</h1>
    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <p class="status-message">@statusMessage</p>
    }
    <dl class="definition-list">
        <dt>@L["Status"]</dt>
        <dd>@Model.Task.Status</dd>
        <dt>@L["Priority"]</dt>
        <dd>@Model.Task.Priority</dd>
        <dt>@L["Due"]</dt>
        <dd>@Model.Task.DueAtUtc?.ToLocalTime().ToString("g")</dd>
        <dt>@L["Started"]</dt>
        <dd>@Model.Task.StartedAtUtc?.ToLocalTime().ToString("g")</dd>
        <dt>@L["Completed"]</dt>
        <dd>@Model.Task.CompletedAtUtc?.ToLocalTime().ToString("g")</dd>
    </dl>

    <form asp-action="UpdateStatus" method="post" class="form">
        <input type="hidden" name="id" value="@Model.Task.Id" />
        <label>
            @L["Status"]
            <select name="status">
                <option value="@MaintenanceTaskStatus.Open">@L["Open"]</option>
                <option value="@MaintenanceTaskStatus.InProgress">@L["InProgress"]</option>
                <option value="@MaintenanceTaskStatus.Done">@L["Done"]</option>
            </select>
        </label>
        <label>
            @L["Notes"]
            <textarea name="notes">@Model.Notes</textarea>
        </label>
        <button type="submit">@L["SaveTaskStatus"]</button>
    </form>

    <a asp-action="Index">@L["BackToMaintenance"]</a>
</section>
