@model MaintenancePageViewModel
@inject IStringLocalizer<SharedResources> L
<section class="panel">
    <h1>@L["Maintenance"]</h1>
    <p>@L["Gym"]: <strong>@Model.GymCode</strong></p>
    @if (Model.Tasks.Count == 0)
    {
        <p class="muted-text">@L["NoMaintenanceTasksAssigned"]</p>
    }
    else
    {
        <table class="data-table">
            <thead>
            <tr>
                <th>@L["Task"]</th>
                <th>@L["Status"]</th>
                <th>@L["Due"]</th>
                <th>@L["Notes"]</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var task in Model.Tasks)
            {
                <tr>
                    <td>@task.TaskType</td>
                    <td>@task.Status</td>
                    <td>@task.DueAtUtc?.ToLocalTime().ToString("g")</td>
                    <td>@task.Notes</td>
                    <td><a asp-action="Details" asp-route-id="@task.Id">@L["Update"]</a></td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>
