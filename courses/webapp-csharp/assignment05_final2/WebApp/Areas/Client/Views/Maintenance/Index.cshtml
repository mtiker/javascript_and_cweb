@model MaintenancePageViewModel
@inject IStringLocalizer<SharedResources> L
<section class="panel">
    <h1>@L["Maintenance"]</h1>
    <p>Gym: <strong>@Model.GymCode</strong></p>
    @if (Model.Tasks.Count == 0)
    {
        <p class="muted-text">No maintenance tasks are assigned to you in the active gym.</p>
    }
    else
    {
        <table class="data-table">
            <thead>
            <tr>
                <th>Task</th>
                <th>Status</th>
                <th>Due</th>
                <th>Notes</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var task in Model.Tasks)
            {
                <tr>
                    <td>@task.TaskType</td>
                    <td>@task.Status</td>
                    <td>@task.DueAtUtc?.ToLocalTime().ToString("g")</td>
                    <td>@task.Notes</td>
                    <td><a asp-action="Details" asp-route-id="@task.Id">Update</a></td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>
