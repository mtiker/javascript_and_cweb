# Local Vite dev server points at the local HTTPS backend.
VITE_API_BASE_URL=https://localhost:7245

# For a separate-host production build, override at build time. Examples:
#   docker build --build-arg VITE_API_BASE_URL=https://api.example.com -t client:latest .
#   VITE_API_BASE_URL=https://api.example.com npm run build
#
# Leave VITE_API_BASE_URL unset to keep same-origin behavior. In that case
# resolveApiBaseUrl() (client/src/lib/auth.tsx) falls back to
# window.location.origin in production, which matches the embedded /client
# deployment served by the backend.
