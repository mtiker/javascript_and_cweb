@model ClientProfilePageViewModel

<section class="panel">
    <p class="eyebrow">Client workspace</p>
    <h1>Profile</h1>
    <p>Active gym: <strong>@Model.GymCode</strong></p>
    <p>Active role: <strong>@Model.ActiveRole</strong></p>
</section>

@if (!Model.ProfileAvailable)
{
    <section class="panel">
        <p class="muted-text">This account does not currently have a member profile in the active gym.</p>
    </section>
}
else
{
    <section class="page-grid">
        <article class="panel">
            <h2>Member record</h2>
            <p><strong>@Model.MemberName</strong></p>
            <p>Member code: @Model.MemberCode</p>
            <p>Status: @Model.MemberStatus</p>
        </article>

        <article class="panel">
            <h2>Memberships</h2>
            @if (Model.Memberships.Count == 0)
            {
                <p class="muted-text">No memberships found.</p>
            }
            else
            {
                <ul class="compact-list">
                    @foreach (var membership in Model.Memberships)
                    {
                        <li>@membership.PackageName | @membership.StartDate - @membership.EndDate | @membership.Status</li>
                    }
                </ul>
            }
        </article>

        <article class="panel">
            <h2>Bookings</h2>
            @if (Model.Bookings.Count == 0)
            {
                <p class="muted-text">No bookings found.</p>
            }
            else
            {
                <ul class="compact-list">
                    @foreach (var booking in Model.Bookings)
                    {
                        <li>@booking.SessionName | @booking.StartAtUtc.ToLocalTime():g | @booking.Status</li>
                    }
                </ul>
            }
        </article>

        <article class="panel">
            <h2>Payments</h2>
            @if (Model.Payments.Count == 0)
            {
                <p class="muted-text">No payments recorded.</p>
            }
            else
            {
                <ul class="compact-list">
                    @foreach (var payment in Model.Payments)
                    {
                        <li>@payment.Amount @payment.CurrencyCode | @payment.PaidAtUtc.ToLocalTime():g | @payment.Status</li>
                    }
                </ul>
            }
        </article>
    </section>
}
