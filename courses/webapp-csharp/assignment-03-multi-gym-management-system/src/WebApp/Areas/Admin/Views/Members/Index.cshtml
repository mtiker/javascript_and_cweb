@model AdminMembersPageViewModel

<section class="panel">
    <p class="eyebrow">Admin workspace</p>
    <h1>Members</h1>
    <p>Active gym: <strong>@Model.GymCode</strong></p>
</section>

<section class="dashboard-grid">
    <article class="metric-card">
        <span>Total members</span>
        <strong>@Model.TotalCount</strong>
    </article>
    <article class="metric-card">
        <span>Active</span>
        <strong>@Model.ActiveCount</strong>
    </article>
    <article class="metric-card">
        <span>Suspended</span>
        <strong>@Model.SuspendedCount</strong>
    </article>
    <article class="metric-card">
        <span>Left</span>
        <strong>@Model.LeftCount</strong>
    </article>
</section>

<section class="panel">
    <h2>Member directory</h2>
    @if (Model.Members.Count == 0)
    {
        <p class="muted-text">No members exist in this gym yet.</p>
    }
    else
    {
        <table class="data-table">
            <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Status</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var member in Model.Members)
            {
                <tr>
                    <td>@member.MemberCode</td>
                    <td>@member.FullName</td>
                    <td>@member.Status</td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>
