@model AdminDashboardViewModel
@inject IStringLocalizer<SharedResources> L
<section class="dashboard-grid">
    <article class="panel">
        <h1>@L["AdminArea"]</h1>
        <p>Active gym: <strong>@(Model.ActiveGymCode ?? "platform")</strong></p>
        <p>Active role: <strong>@(Model.ActiveRole ?? string.Join(", ", Model.SystemRoles))</strong></p>
    </article>
    <article class="metric-card">
        <span>@L["Gyms"]</span>
        <strong>@Model.GymCount</strong>
    </article>
    <article class="metric-card">
        <span>@L["Members"]</span>
        <strong>@Model.MemberCount</strong>
    </article>
    <article class="metric-card">
        <span>@L["Sessions"]</span>
        <strong>@Model.SessionCount</strong>
    </article>
    <article class="metric-card">
        <span>@L["Maintenance"]</span>
        <strong>@Model.OpenMaintenanceTaskCount</strong>
    </article>
</section>
<section class="panel">
    <h2>Quick links</h2>
    <div class="link-strip">
        <a asp-area="Admin" asp-controller="Gyms" asp-action="Index">@L["Gyms"]</a>
        <a asp-area="Admin" asp-controller="Memberships" asp-action="Index">Memberships</a>
        <a asp-area="Admin" asp-controller="Sessions" asp-action="Index">@L["Sessions"]</a>
        <a asp-area="Admin" asp-controller="Operations" asp-action="Index">Operations</a>
    </div>
</section>
