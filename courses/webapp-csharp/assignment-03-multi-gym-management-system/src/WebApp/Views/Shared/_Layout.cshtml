@using System.Globalization
@using App.BLL.Services
@using App.Domain
@inject IStringLocalizer<SharedResources> L
@inject IConfiguration Configuration
@inject IUserContextService UserContextService
@{
    var clientAppBaseUrl = ClientAppUrlResolver.GetBaseUrl(Configuration);
    var userContext = User.Identity?.IsAuthenticated == true ? UserContextService.GetCurrent() : null;
    var canAccessAdminArea = userContext is not null &&
                             (userContext.HasRole(RoleNames.SystemAdmin) ||
                              userContext.HasRole(RoleNames.SystemSupport) ||
                              userContext.HasRole(RoleNames.SystemBilling) ||
                              userContext.HasRole(RoleNames.GymOwner) ||
                              userContext.HasRole(RoleNames.GymAdmin));
}
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@L["AppTitle"]</title>
    <link rel="icon" type="image/svg+xml" href="~/assets/gym-logo.svg" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header class="topbar">
        <div>
            <strong>@L["AppTitle"]</strong>
        </div>
        <nav class="topnav">
            @if (User.Identity?.IsAuthenticated == true)
            {
                @if (canAccessAdminArea)
                {
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index">@L["AdminArea"]</a>
                }
                <a href="@clientAppBaseUrl">@L["ClientArea"]</a>
                <a asp-area="Client" asp-controller="Profile" asp-action="Index">@L["Profile"]</a>
            }
        </nav>
        <div class="topbar-actions">
            <partial name="_CultureSwitcher" />
            @if (User.Identity?.IsAuthenticated == true)
            {
                <vc:workspace-switcher></vc:workspace-switcher>
                <form asp-area="" asp-controller="Home" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit">@L["Logout"]</button>
                </form>
            }
        </div>
    </header>
    <main class="page-shell">
        @RenderBody()
    </main>
</body>
</html>
