# Sample build-time configuration for a separate-host client deployment.
# Copy or set these as build args / CI variables before running `vite build`.
#
# Required when the client is hosted on a different origin from the API:
VITE_API_BASE_URL=https://mtiker-cweb-4.proxy.itcollege.ee

# Leave VITE_API_BASE_URL unset (or omit this file) to keep the same-origin
# fallback. resolveApiBaseUrl() in client/src/lib/auth.tsx defaults to
# window.location.origin when PROD is true and no explicit URL is given.
